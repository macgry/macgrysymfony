{% extends 'base.html.twig' %}

{% block title %}
    {{ category.title }}
{% endblock %}

{% block body %}

    <div class="container mt-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="mb-0">{{ category.title }}</h1>

            <div>
                <a href="{{ url('category_index') }}" class="btn btn-secondary">
                    {{ 'action.back_to_list'|trans }}
                </a>

                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ url('category_edit', {id: category.id}) }}" class="btn btn-warning">
                        {{ 'action.edit'|trans }}
                    </a>

                    <a href="{{ url('category_delete', {id: category.id}) }}" class="btn btn-danger">
                        {{ 'action.delete'|trans }}
                    </a>
                {% endif %}
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <p class="mb-1"><strong>ID:</strong> {{ category.id }}</p>
                <p class="mb-1"><strong>{{ 'label.title'|trans }}:</strong> {{ category.title }}</p>
                <p class="mb-1"><strong>{{ 'label.slug'|trans }}:</strong> {{ category.slug }}</p>
                <p class="mb-1"><strong>{{ 'label.created_at'|trans }}:</strong> {{ category.createdAt|format_date('long') }}</p>
                <p class="mb-0"><strong>{{ 'label.updated_at'|trans }}:</strong> {{ category.updatedAt|format_date('long') }}</p>
            </div>
        </div>

        <h3 class="mb-3">{{ 'title.category_posts'|trans }}</h3>

        {% if posts|length > 0 %}
            <div class="list-group">
                {% for post in posts %}
                    <a href="{{ url('post_view', {id: post.id}) }}"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span>{{ post.title }}</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="alert alert-info mt-3">
                {{ 'message.empty_list'|trans }}
            </div>
        {% endif %}

    </div>

{% endblock %}
