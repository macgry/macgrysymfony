{% extends 'base.html.twig' %}

{% block title %}
    {{ 'action.delete'|trans }}
{% endblock %}

{% block body %}
    <h1>{{ 'action.delete'|trans }}</h1>

    <p>Are you sure you want to delete this post?</p>

    <form method="post">
        <button class="btn btn-danger">
            {{ 'action.delete'|trans }}
        </button>
    </form>

    <a href="{{ url('post_index') }}" class="btn btn-secondary">
        {{ 'action.back_to_list'|trans }}
    </a>
{% endblock %}
