{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.post_list'|trans }}
{% endblock %}

{% block body %}
    <h1>{{ 'title.post_list'|trans }}</h1>

    {% if pagination is defined and pagination.items|length %}

        <div class="mb-3">
            <a class="btn btn-success" href="{{ url('post_create') }}">
                {{ 'action.create'|trans }}
            </a>
        </div>

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

        <table class="table table-striped">
            <thead>
            <tr>
                <th>{{ knp_pagination_sortable(pagination, 'ID', 'post.id') }}</th>
                <th>{{ knp_pagination_sortable(pagination, 'Title', 'post.title') }}</th>
                <th>{{ knp_pagination_sortable(pagination, 'Category', 'category.title') }}</th>
                <th>{{ 'label.actions'|trans }}</th>
            </tr>
            </thead>

            <tbody>
            {% for post in pagination.items %}
                <tr>
                    <td>{{ post.id }}</td>
                    <td>{{ post.title }}</td>
                    <td>{{ post.category.title }}</td>
                    <td>
                        <a href="{{ url('post_view', {id: post.id}) }}" class="btn btn-sm btn-primary">
                            {{ 'action.view'|trans }}
                        </a>

                        <a href="{{ url('post_edit', {id: post.id}) }}" class="btn btn-sm btn-warning">
                            {{ 'action.edit'|trans }}
                        </a>

                        <a href="{{ url('post_delete', {id: post.id}) }}" class="btn btn-sm btn-danger">
                            {{ 'action.delete'|trans }}
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

    {% else %}
        <p>{{ 'message.empty_list'|trans }}</p>
    {% endif %}
{% endblock %}
