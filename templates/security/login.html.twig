{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.login'|trans }}
{% endblock %}

{% block body %}
    <form method="post" action="{{ path('app_login') }}">
        {% if error %}
            <div class="alert alert-danger">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                {{ 'message.logged_in_as'|trans({'%user%': app.user.userIdentifier}) }}
                <a href="{{ logout_path() }}">{{ 'action.logout'|trans }}</a>
            </div>
        {% endif %}

        <h1 class="h3 mb-3 font-weight-normal">
            {{ 'title.please_sign_in'|trans }}
        </h1>

        <label for="username">{{ 'label.email'|trans }}</label>
        <input type="email"
               value="{{ last_username }}"
               name="_username"
               id="username"
               class="form-control"
               autocomplete="email"
               required
               autofocus>

        <label for="password">{{ 'label.password'|trans }}</label>
        <input type="password"
               name="_password"
               id="password"
               class="form-control"
               autocomplete="current-password"
               required>

        <input type="hidden"
               name="_csrf_token"
               data-controller="csrf-protection"
               value="{{ csrf_token('authenticate') }}">

        <button class="btn btn-lg btn-primary mt-3" type="submit">
            {{ 'action.login'|trans }}
        </button>
    </form>
{% endblock %}
